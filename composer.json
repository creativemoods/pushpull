{
    "name": "creativemoods/pushpull",
    "description": "Git-backed content workflows for selected WordPress content domains.",
    "keywords": [
        "wordpress",
        "plugin",
        "git",
        "devops",
        "content sync"
    ],
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "homepage": "https://github.com/CreativeMoods/pushpull",
    "support": {
        "issues": "https://github.com/CreativeMoods/pushpull/issues",
        "source": "https://github.com/CreativeMoods/pushpull"
    },
    "require": {
        "composer/installers": "^2.0",
        "php": "^8.1"
    },
    "require-dev": {
        "php-stubs/wordpress-stubs": "^6.8",
        "phpstan/phpstan": "^1.12",
        "phpunit/phpunit": "^11.5",
        "squizlabs/php_codesniffer": "^3.13",
        "szepeviktor/phpstan-wordpress": "^1.3"
    },
    "autoload": {
        "psr-4": {
            "PushPull\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PushPull\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpcs": "phpcs --standard=phpcs.xml.dist",
        "phpstan": "phpstan analyse --configuration=phpstan.neon.dist --no-progress --debug --memory-limit=1G",
        "bump-version": "sh bin/bump-version.sh",
        "sync-public-github": "sh bin/sync-public-github.sh",
        "pcp": "sh bin/run-pcp.sh",
        "package": "sh bin/package-plugin.sh",
        "deploy-wordpress-svn": "sh bin/deploy-wordpress-svn.sh"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/installers": true
        }
    }
}
